{
  "name": "youtube-shorts-generator",
  "version": "1.0.0",
  "description": "Generate YouTube Shorts videos using Remotion with mobile app design",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render",
    "upgrade": "remotion upgrade",
    "render": "remotion render Root mp4",
    "render:headless": "node render.js",
    "render:headless:hq": "node render.js \"\" high",
    "render:headless:fast": "node render.js \"\" fast",
    "render:test": "remotion render AnimationTest out/test-video.mp4",
    "render:custom": "node render.js",
    "render:batch": "node batch-render.js",
    "start:server": "ts-node --project tsconfig.server.json server.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
