    "@remotion/zod-types": "4.0.314",
    "@types/express": "^4.17.21",
    "dotenv": "^17.0.1",
    "express": "^4.19.2",
    "music-metadata": "^11.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.314",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
